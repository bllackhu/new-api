# @douyinfe/vite-plugin-semi alpha pins peer vite@5.1.0; project uses vite ^5.2 (e.g. 5.4.x). Safe for this UI build.
legacy-peer-deps=true

# npm ci requires package-lock.json committed and in sync; run npm install after package.json changes, then commit the lockfile.
#
# Windows EPERM unlink node_modules\.bin\vite.exe: stop `npm run dev`, close IDEs using that Vite,
# then `Remove-Item -Recurse -Force node_modules` and run `npm ci` again (or reboot if a zombie node holds the file).
